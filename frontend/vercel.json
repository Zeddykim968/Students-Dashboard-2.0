{
  "buildCommand": "npm install --legacy-peer-deps && npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://student-uploads-api.onrender.com/api/:path*"
    },
    {
      "source": "/uploads/:path*",
      "destination": "https://student-uploads-api.onrender.com/uploads/:path*"
    },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
